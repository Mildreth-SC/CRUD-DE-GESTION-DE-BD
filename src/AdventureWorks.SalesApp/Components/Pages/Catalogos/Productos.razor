@page "/catalogos/productos"
@rendermode InteractiveServer
@attribute [Authorize]
@inject ICatalogoService CatalogoService

<PageTitle>Productos</PageTitle>

<h3>Catálogo de Productos (Production.Product)</h3>

@if (!string.IsNullOrEmpty(error)) { <div class="alert alert-danger">@error</div> }
@if (!string.IsNullOrEmpty(mensaje)) { <div class="alert alert-info">@mensaje</div> }

<div class="row mb-3">
    <div class="col-md-4"><input class="form-control" placeholder="Buscar..." @bind="busqueda" /></div>
    <div class="col-auto">
        <button class="btn btn-secondary" @onclick="Cargar">Buscar</button>
        <button class="btn btn-primary" @onclick="Nuevo">Nuevo</button>
    </div>
</div>

@if (editando)
{
    <div class="card mb-3"><div class="card-body row g-2">
        <div class="col-md-3"><label class="form-label">Nombre</label><input class="form-control" @bind="form.Name" /></div>
        <div class="col-md-2"><label class="form-label">Número</label><input class="form-control" @bind="form.ProductNumber" /></div>
        <div class="col-md-2"><label class="form-label">Precio</label><input type="number" step="0.01" class="form-control" @bind="form.ListPrice" /></div>
        <div class="col-md-2"><label class="form-label">Costo</label><input type="number" step="0.01" class="form-control" @bind="form.StandardCost" /></div>
        <div class="col-md-2"><label class="form-label">Subcat. ID</label><input type="number" class="form-control" @bind="form.ProductSubcategoryID" /></div>
        <div class="col-md-1 d-flex align-items-end"><button class="btn btn-success w-100" @onclick="Guardar">OK</button></div>
    </div></div>
}

<table class="table table-striped table-sm">
    <thead class="table-dark"><tr><th>ID</th><th>Nombre</th><th>Número</th><th>Precio</th><th>Subcategoría</th><th>Categoría</th><th></th></tr></thead>
    <tbody>
        @foreach (var p in productos)
        {
            <tr>
                <td>@p.ProductID</td><td>@p.Name</td><td>@p.ProductNumber</td>
                <td>@p.ListPrice.ToString("C")</td><td>@p.Subcategoria</td><td>@p.Categoria</td>
                <td>
                    <button class="btn btn-sm btn-warning" @onclick="() => Editar(p)">Editar</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(p.ProductID)">Eliminar</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<ProductoDto> productos = [];
    private ProductoDto form = new();
    private bool editando;
    private string busqueda = "";
    private string? mensaje, error;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        error = null;
        try { productos = (await CatalogoService.ListarProductosAsync(string.IsNullOrWhiteSpace(busqueda) ? null : busqueda)).ToList(); }
        catch (Exception ex) { error = ex.Message; }
    }

    private void Nuevo() { form = new(); editando = true; }
    private void Editar(ProductoDto p) { form = new ProductoDto { ProductID = p.ProductID, Name = p.Name, ProductNumber = p.ProductNumber, ListPrice = p.ListPrice, StandardCost = p.StandardCost, ProductSubcategoryID = p.ProductSubcategoryID }; editando = true; }

    private async Task Guardar()
    {
        try { await CatalogoService.GuardarProductoAsync(form); mensaje = "Guardado."; editando = false; await Cargar(); }
        catch (Exception ex) { error = ex.Message; }
    }

    private async Task Eliminar(int id)
    {
        try { await CatalogoService.EliminarProductoAsync(id); mensaje = "Eliminado."; await Cargar(); }
        catch (Exception ex) { error = ex.Message; }
    }
}
