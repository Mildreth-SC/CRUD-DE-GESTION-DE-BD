@page "/reportes/productos"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IReporteService ReporteService
@inject ICatalogoService CatalogoService

<PageTitle>Reporte por Producto</PageTitle>

<h3>Detalle / Resumen de Ventas por Producto</h3>

<div class="card mb-3"><div class="card-body row g-2">
    <div class="col-md-2"><label class="form-label">Desde</label><InputDate class="form-control" @bind-Value="filtro.FechaInicio" /></div>
    <div class="col-md-2"><label class="form-label">Hasta</label><InputDate class="form-control" @bind-Value="filtro.FechaFin" /></div>
    <div class="col-md-4">
        <label class="form-label">Producto</label>
        <select class="form-select" @bind="filtro.ProductID">
            <option value="">Todos</option>
            @foreach (var p in productos) { <option value="@p.ProductID">@p.Name</option> }
        </select>
    </div>
    <div class="col-auto d-flex align-items-end gap-2">
        <button class="btn btn-primary" @onclick="() => Generar(true)">Detalle</button>
        <button class="btn btn-secondary" @onclick="() => Generar(false)">Resumen</button>
    </div>
</div></div>

@if (!string.IsNullOrEmpty(error)) { <div class="alert alert-danger">@error</div> }

@if (modoDetalle)
{
    <table class="table table-sm table-striped">
        <thead class="table-dark"><tr><th>Producto</th><th>Orden</th><th>Fecha</th><th>Cant.</th><th>Precio</th><th>Total</th></tr></thead>
        <tbody>
            @foreach (var r in datos) { <tr><td>@r.Producto</td><td>@r.SalesOrderNumber</td><td>@r.OrderDate?.ToString("dd/MM/yy")</td><td>@r.OrderQty</td><td>@r.UnitPrice?.ToString("C")</td><td>@r.LineTotal?.ToString("C")</td></tr> }
        </tbody>
    </table>
}
else if (datos.Any())
{
    <table class="table table-striped">
        <thead class="table-dark"><tr><th>Producto</th><th>Número</th><th>Cantidad</th><th>Total Ventas</th></tr></thead>
        <tbody>
            @foreach (var r in datos) { <tr><td>@r.Producto</td><td>@r.ProductNumber</td><td>@r.CantidadVendida</td><td class="fw-bold">@r.TotalVentas?.ToString("C")</td></tr> }
        </tbody>
    </table>
}

@code {
    private FiltroReporteVentas filtro = new();
    private List<ProductoDto> productos = [];
    private List<ReporteProductoDto> datos = [];
    private bool modoDetalle;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try { productos = (await CatalogoService.ListarProductosAsync()).ToList(); }
        catch (Exception ex) { error = ex.Message; }
    }

    private async Task Generar(bool detalleMode)
    {
        error = null; modoDetalle = detalleMode;
        try
        {
            datos = detalleMode
                ? (await ReporteService.DetallePorProductoAsync(filtro)).ToList()
                : (await ReporteService.ResumenPorProductoAsync(filtro)).ToList();
        }
        catch (Exception ex) { error = ex.Message; }
    }
}
